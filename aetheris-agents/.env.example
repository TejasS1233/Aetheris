GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

MQTT_BROKER=localhost
MQTT_PORT=1883
EXCEPTIONS_TOPIC=aetheris/exceptions
COMMANDS_TOPIC=aetheris/commands
DISCUSSION_TOPIC=aetheris/internal/discussion
CONSENSUS_TOPIC=aetheris/consensus

REDIS_URL=redis://localhost:6379/0
REDIS_IMMEDIATE_STREAM=aetheris:stream:immediate
REDIS_BATCH_STREAM=aetheris:stream:batch
REDIS_CONSUMER_GROUP=aetheris-agents
REDIS_CONSUMER_NAME=orchestrator-1
IMMEDIATE_SCORE_THRESHOLD=0.9
BATCH_SIZE=10
IMMEDIATE_BATCH_SIZE=5
IMMEDIATE_BATCH_MAX_WAIT_MS=150
BATCH_MAX_WAIT_MS=300
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=aetheris
MONGODB_TRANSACTIONS_COLLECTION=transactions
MONGODB_EXCEPTIONS_COLLECTION=exceptions
MONGODB_COMMANDS_COLLECTION=commands
MONGODB_TOOL_AUDIT_COLLECTION=tool_audit
MONGODB_AUDIT_TTL_DAYS=30

FAIL_FAST_HEALTHCHECK=true
